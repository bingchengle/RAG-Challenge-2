# 复制本文件为 .env 后填写（.env 已被 git 忽略）
# MySQL（与 schema.sql 中建库名 teddy_b 一致）
TEDDY_MYSQL_DSN=mysql+pymysql://root:你的密码@127.0.0.1:3306/teddy_b

# --- 大模型：智谱 GLM（对话）+ BGE（向量，如硅基流动）。也可只配系统环境变量 ---
# GLM_API_KEY=  或  ZHIPU_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4.7-flash
# BGE_API_KEY=
# BGE_BASE_URL=https://api.siliconflow.cn/v1
# BGE_EMBEDDING_MODEL=BAAI/bge-m3
# 以上 GLM + BGE 均为必填（本工程不调用 OpenAI 官方 API）
